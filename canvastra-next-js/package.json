{
  "name": "canvastra-next-js",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@trpc/server": "^11.7.2",
      "better-auth": "^1.4.7",
      "@trpc/client": "^11.7.2"
    }
  },
  "type": "module",
  "scripts": {
    "check": "biome check --write .",
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @canvastra-next-js/db db:push",
    "db:studio": "turbo -F @canvastra-next-js/db db:studio",
    "db:generate": "turbo -F @canvastra-next-js/db db:generate",
    "db:migrate": "turbo -F @canvastra-next-js/db db:migrate",
    "db:seed": "turbo -F @canvastra-next-js/db db:seed",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "test:coverage": "turbo test:coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "bun run test && bun run test:e2e"
  },
  "dependencies": {
    "@trpc/react-query": "^11.8.1",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@faker-js/faker": "^10.1.0",
    "@playwright/test": "^1.48.0",
    "@types/bun": "catalog:",
    "turbo": "^2.6.3",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.5"
}